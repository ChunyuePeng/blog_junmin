<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.junmin.mapper.ArticleTagMapper">

    <select id="selectTagIdsByArticleId" resultType="long">
        SELECT tag_id FROM article_tags WHERE article_id = #{articleId}
    </select>

    <insert id="batchInsert">
        INSERT INTO article_tags (article_id, tag_id)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.articleId}, #{item.tagId})
        </foreach>
    </insert>

    <delete id="deleteByArticleId">
        DELETE FROM article_tags WHERE article_id = #{articleId}
    </delete>

</mapper>