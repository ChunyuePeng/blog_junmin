<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.junmin.mapper.SysRoleMapper">

    <resultMap id="roleMap" type="org.example.junmin.entity.SysRole">
        <id column="id" property="id"/>
        <result column="role_name" property="roleName"/>
        <result column="role_code" property="roleCode"/>
        <result column="description" property="description"/>
    </resultMap>

    <select id="selectById" resultMap="roleMap">
        SELECT * FROM sys_role WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="roleMap">
        SELECT * FROM sys_role
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role(role_name, role_code, description)
        VALUES (#{roleName}, #{roleCode}, #{description})
    </insert>

    <update id="update">
        UPDATE sys_role
        SET role_name = #{roleName},
        role_code = #{roleCode},
        description = #{description}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_role WHERE id = #{id}
    </delete>




</mapper>